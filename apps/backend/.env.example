# App
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_URL="postgresql://postgres:password@postgres:5432/wikso"

# Auth
JWT_SECRET="super-secret-key-change-me"
JWT_REFRESH_SECRET="refresh-secret-change-me"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
EMAIL_VERIFICATION_REQUIRED=false
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# SAML SSO (optional — leave empty to disable)
SAML_ENTRY_POINT=""
SAML_ISSUER="wikso"
SAML_CERT=""
SAML_CALLBACK_URL="http://localhost:3000/api/auth/saml/callback"

# Redis (Queue & Cache)
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO (S3 Compatible)
S3_ENDPOINT="http://minio:9000"
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="wikso-uploads"
S3_REGION="us-east-1"

# Meilisearch (Search)
MEILISEARCH_HOST="http://meilisearch:7700"
MEILISEARCH_API_KEY="masterKey"

# Hocuspocus
HOCUSPOCUS_PORT=1234

# Mail
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USER="user"
MAIL_PASS="pass"
MAIL_FROM="noreply@wikso.local"

# Admin seed (creates admin user on first start if not exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!
