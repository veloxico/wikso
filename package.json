{
  "name": "wikso",
  "version": "2.4.4",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev:backend": "turbo dev --filter=@wikso/backend",
    "dev:frontend": "turbo dev --filter=@wikso/frontend"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "patchedDependencies": {
      "@tiptap/react@3.20.1": "patches/@tiptap__react@3.20.1.patch"
    }
  }
}
